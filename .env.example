# CloverDX Data Manager MCP Server Configuration
# Copy this file to .env and update with your CloverDX instance details

# CloverDX Data Manager Base URL (without trailing slash)
export CLOVERDX_BASE_URL=http://britannicus:29091/clover

# CloverDX Username with Data Manager API access
export CLOVERDX_USERNAME=clover

# CloverDX Password
export CLOVERDX_PASSWORD=clover

# Optional: TCP Server Configuration (for dm_mcp_server_tcp.py)
export TCP_HOST=localhost
export TCP_PORT=9999

# Optional: Verify SSL certificate when connecting to CloverDX server (true/false)
# Set to true in production environments with valid certificates
export CLOVERDX_VERIFY_SSL=false

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
export LOG_LEVEL=INFO

# Optional: HTTP timeout in seconds
export HTTP_TIMEOUT=30

# Optional: LLM settings for CTL validation/generation tools
# OpenAI-compatible chat completions endpoint (Ollama default)
export CLOVERDX_LLM_API_URL=http://localhost:11434/v1/chat/completions

# Model name used for validate_CTL and generate_CTL
export CLOVERDX_LLM_MODEL=Qwen35_CTL:latest

# Sampling parameters
export CLOVERDX_LLM_TEMPERATURE=0.2
export CLOVERDX_LLM_TOP_P=0.9

# Optional: file path for CTL tool logs (set empty to disable file logging)
export CLOVERDX_LOG_PATH=./logs/ctl_tools.log